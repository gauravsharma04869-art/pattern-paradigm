---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/', label: 'Home' },
  { href: '/philosophy', label: 'Philosophy' },
  { href: '/science', label: 'Science' },
  { href: '/about', label: 'About' },
  { href: '/journal', label: 'Journal' },
];
---

<nav class="fixed top-0 left-0 w-full z-50 glass-nav transition-transform duration-300" role="navigation" aria-label="Main navigation" id="nav">
  <div class="max-w-7xl mx-auto flex justify-between items-center px-4 sm:px-6 lg:px-8 h-16 md:h-20">
    <a href="/" class="flex items-center gap-3">
      <img src="/apple-touch-icon.png" alt="Pattern Paradigm" class="h-9 w-9 rounded-lg" />
      <span class="font-display text-2xl text-primary tracking-tight">Pattern Paradigm</span>
    </a>
    <div class="hidden md:flex items-center gap-8 uppercase tracking-[0.15em] text-sm">
      {links.map(link => (
        <a href={link.href} class={`nav-link ${currentPath === link.href ? '!text-primary !after:w-full' : ''}`}>
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-4">
      <a href="/waitlist" class="hidden sm:inline-block bg-primary text-background px-5 py-2 rounded text-xs uppercase tracking-[0.15em] hover:brightness-110 transition-all active:scale-95">Join the Waitlist</a>
      <button id="menuBtn" class="md:hidden p-2 text-on-surface hover:text-primary transition-colors" aria-label="Toggle menu" aria-expanded="false">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path id="menuOpen" stroke-linecap="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
          <path id="menuClose" class="hidden" stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>
  <div id="mobileMenu" class="md:hidden hidden border-t border-white/5 bg-background/95 backdrop-blur-md">
    <div class="px-4 py-4 space-y-3">
      {links.map(link => (
        <a href={link.href} class={`block px-3 py-2 text-lg transition-colors ${currentPath === link.href ? 'text-primary' : 'text-on-surface hover:text-primary'}`}>
          {link.label}
        </a>
      ))}
      <a href="/waitlist" class="block px-3 py-2 text-primary text-lg font-medium">Join the Waitlist →</a>
    </div>
  </div>
</nav>
